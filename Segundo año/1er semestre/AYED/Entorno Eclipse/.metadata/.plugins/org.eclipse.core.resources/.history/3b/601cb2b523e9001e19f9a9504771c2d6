package ar.edu.info.unlp.ejercicio1;

public class Twitter {
private List<Usuario> usuarios = new ArrayList<>();
	
	public Twitter() {
		
		}
	public Usuario agregarUsuario(String nombre) {
		if (this.usuarios.stream().anyMatch(usuario -> usuario.getNombre().equals(nombre))) {
			return null;
		}
		else {
			Usuario usu = new Usuario(nombre);
			return usu;
		}
		
	}
	public Usuario eliminarUsuario(Usuario usr) {
		Usuario usus=this.usuarios.stream().filter(usu -> usu.getNombre().equals(usr.getNombre())).findFirst().orElse(null);
		usus.eliminarTweets();
		this.usuarios.remove(usus);
		return usus;
	}
}
